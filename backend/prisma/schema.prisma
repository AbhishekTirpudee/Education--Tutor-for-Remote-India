generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Textbook {
  id          Int         @id @default(autoincrement())
  filename    String
  subject     String?
  grade       String?
  totalPages  Int         @default(0)
  totalChunks Int         @default(0)
  filePath    String
  createdAt   DateTime    @default(now())
  queries     QueryLog[]
  chunks      TextChunk[]
}

model TextChunk {
  id         Int      @id @default(autoincrement())
  textbookId Int
  chunkIndex Int
  pageNumber Int?
  chapter    String?
  content    String
  tokenCount Int      @default(0)
  embedding  String?
  textbook   Textbook @relation(fields: [textbookId], references: [id], onDelete: Cascade)
}

model QueryLog {
  id              Int       @id @default(autoincrement())
  textbookId      Int?
  question        String
  answer          String?
  totalChunks     Int?
  prunedChunks    Int?
  reductionPct    Float?
  baselineTokens  Int?
  prunedTokens    Int?
  tokensSaved     Int?
  baselineCostUsd Float?
  actualCostUsd   Float?
  costSavedUsd    Float?
  latencyMs       Float?
  createdAt       DateTime  @default(now())
  textbook        Textbook? @relation(fields: [textbookId], references: [id])
}

model TutoringSession {
  id           String   @id @default(uuid())
  studentName  String?
  grade        String?
  subject      String?
  startedAt    DateTime @default(now())
  totalQueries Int      @default(0)
  totalCostUsd Float    @default(0)
  tokensSaved  Int      @default(0)
  isActive     Boolean  @default(true)
}
